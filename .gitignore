# --- Swift Package Manager ---
.build/
.swiftpm/
.swiftpm-xcode/
# Package.resolved is intentionally NOT ignored: this template ships an app (an executable
# product), so its resolved dependency versions are committed for reproducible builds — and
# Dependabot's Swift updater reads the committed Package.resolved.
Packages/
*.xcodeproj
*.xcworkspace
xcuserdata/
DerivedData/

# --- Xcode ---
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# --- Build / release artifacts ---
build/
dist/
*.o
*.a
*.dylib
*.so
*.lock
*.xcarchive

# --- Secrets / signing (never commit) ---
*.p12
*.cer
*.key
*.mobileprovision
*.provisionprofile
AuthKey_*.p8
.env
.env.*
!.env.example

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Claude Code: commit shared .claude/settings.json; ignore personal overrides ---
.claude/settings.local.json

# --- Logs ---
*.log
logs/
